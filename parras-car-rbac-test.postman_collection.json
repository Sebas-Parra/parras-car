        {
          "name": "[ADMIN] Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.collectionVariables.set('admin_token',   body.access_token);",
            "pm.collectionVariables.set('admin_user_id', body.user_id);",
            "pm.test('rol admin presente', () => pm.expect(body.roles).to.include('admin'));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin123!\"\n}" },
            "url": { "raw": "{{base_url}}/users/auth/login", "host": ["{{base_url}}"], "path": ["users","auth","login"] }
          }
        },

        {
          "name": "[ROOT] Login",
          "event": [{ "listen": "test", "script": { "exec": [
