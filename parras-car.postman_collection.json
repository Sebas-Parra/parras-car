      "item": [
        {
          "name": "Listar todos los places",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/zones/api/v1/places",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "zones",
                "api",
                "v1",
                "places"
              ]
            }
          }
        },
        {
          "name": "Filtrar por status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/zones/api/v1/places?status=AVAILABLE",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "zones",
                "api",
                "v1",
                "places"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "AVAILABLE"
                }
              ]
            }
          }
        },
        {
          "name": "Filtrar por zona y status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/zones/api/v1/places?zone={{zone_id}}&status=available",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "zones",
                "api",
                "v1",
                "places"
              ],
              "query": [
                {
                  "key": "zone",
                  "value": "{{zone_id}}"
                },
                {
                  "key": "status",
                  "value": "available"
                }
              ]
            }
          }
        },
        {
          "name": "Crear place tipo CAR",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/zones/api/v1/places",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "zones",
                "api",
                "v1",
                "places"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idZone\": \"{{zone_id}}\",\n  \"description\": \"Lugar para auto compacto\",\n  \"type\": \"CAR\"\n}"
            }
          }
        },
        {
          "name": "Crear place tipo BIKE",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/zones/api/v1/places",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "zones",
                "api",
                "v1",
                "places"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idZone\": \"{{zone_id}}\",\n  \"type\": \"BIKE\"\n}"
            }
          }
        },
        {
          "name": "Actualizar place",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/zones/api/v1/places/{{place_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "zones",
                "api",
                "v1",
                "places",
                "{{place_id}}"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idZone\": \"{{zone_id}}\",\n  \"description\": \"Descripción actualizada\",\n  \"type\": \"CAR\"\n}"
            }
          }
        },
        {
          "name": "Cambiar status → OCCUPIED",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/zones/api/v1/places/{{place_id}}/status",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "zones",
                "api",
                "v1",
                "places",
                "{{place_id}}",
                "status"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"OCCUPIED\"\n}"
            }
          }
        },
        {
          "name": "Cambiar status → AVAILABLE",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/zones/api/v1/places/{{place_id}}/status",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "zones",
                "api",
                "v1",
                "places",
                "{{place_id}}",
                "status"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"AVAILABLE\"\n}"
            }
          }
        },
        {
          "name": "Cambiar status (minúsculas)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/zones/api/v1/places/{{place_id}}/status",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "zones",
                "api",
                "v1",
                "places",
                "{{place_id}}",
                "status"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"maintenance\"\n}"
            }
          }
        },
        {
          "name": "Eliminar place",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/zones/api/v1/places/{{place_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "zones",
                "api",
                "v1",
                "places",
                "{{place_id}}"
              ]
            }
          }
        }
      ]
    },
